    "canvas": "^3.2.1",
    "dotenv": "^16.4.5",
    "fastify": "^5.1.0",
    "jsqr": "^1.4.0",
    "nanoid": "^5.0.9",
    "next": "^15.3.0",
    "playwright-core": "^1.57.0",
    "puppeteer": "^24.43.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.10.0",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@types/ws": "^8.5.14",
