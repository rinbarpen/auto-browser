{
  "name": "hxcy-collector",
  "version": "0.1.0",
  "description": "hxcy.top resource collection and visualization",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "next build",
    "dev": "tsx server.ts",
    "start": "NODE_ENV=production tsx server.ts",
    "crawl": "tsx src/cli/crawl.ts",
