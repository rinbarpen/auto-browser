{
  "manifest_version": 3,
  "name": "Auto Browser",
  "version": "0.2.0",
  "description": "AI-powered browser automation sidebar. Submit tasks, handle CAPTCHA verification, and resume execution — all from the side panel.",
  "permissions": ["sidePanel", "storage", "tabs", "activeTab", "scripting"],
  "host_permissions": ["http://127.0.0.1:4317/*", "http://localhost:4317/*"],
  "optional_host_permissions": ["http://*/*", "https://*/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Open Auto Browser"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+A"
      },
      "description": "Open Auto Browser sidebar"
    }
  }
}
